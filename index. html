<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --ink:#1a1a18;--ink-muted:#5a5a55;--ink-faint:#9a9a92;
  --paper:#faf8f3;--paper-alt:#f2f0ea;--rule:#ccc9bc;--red:#8b1a1a;
  --serif:'Playfair Display',Georgia,serif;
  --body:'Source Serif 4',Georgia,serif;
  --sans:'Barlow',sans-serif;
}
html{scroll-behavior:smooth;}
body{background:var(--paper);color:var(--ink);font-family:var(--body);font-size:16px;line-height:1.6;}
/* header */
.site-header{border-bottom:1px solid var(--rule);padding:10px 32px 0;}
.header-top{display:flex;align-items:center;justify-content:space-between;padding-bottom:8px;border-bottom:1px solid var(--rule);margin-bottom:10px;}
.header-meta{font-family:var(--sans);font-size:11px;color:var(--ink-muted);}
.site-name{font-family:var(--serif);font-size:50px;font-weight:700;letter-spacing:-1.5px;line-height:1;text-align:center;flex:1;}
.site-tagline{font-family:var(--sans);font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-muted);text-align:center;margin-top:4px;padding-bottom:10px;}
.nav{display:flex;border-top:2px solid var(--ink);border-bottom:1px solid var(--rule);flex-wrap:wrap;}
.nav a{font-family:var(--sans);font-size:11.5px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--ink);text-decoration:none;padding:8px 16px;cursor:pointer;transition:background .15s;}
.nav a:hover,.nav a.active{background:var(--ink);color:var(--paper);}
/* closure banner */
.closure-banner{background:#f5ede8;border-bottom:2px solid #8b1a1a;padding:10px 32px;font-family:var(--sans);font-size:12px;color:#8b1a1a;text-align:center;line-height:1.5;}
.closure-banner strong{font-weight:700;}
/* page */
.page{max-width:1100px;margin:0 auto;padding:28px 32px 60px;}
.view{display:none;}.view.active{display:block;}
/* section banners */
.section-banner{font-family:var(--sans);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.14em;border-top:2px solid var(--ink);border-bottom:1px solid var(--rule);padding:6px 0;margin-bottom:20px;display:flex;justify-content:space-between;align-items:center;}
.section-banner span{color:var(--ink-muted);font-weight:400;}
/* typography */
.kicker{font-family:var(--sans);font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.14em;color:var(--ink-muted);margin-bottom:5px;}
.kicker.hot{color:var(--red);}
h1.hed{font-family:var(--serif);font-size:32px;font-weight:700;line-height:1.15;margin-bottom:9px;cursor:pointer;}
h1.hed:hover{text-decoration:underline;text-underline-offset:3px;}
h2.hed{font-family:var(--serif);font-size:20px;font-weight:700;line-height:1.2;margin-bottom:8px;cursor:pointer;}
h2.hed:hover{text-decoration:underline;text-underline-offset:3px;}
h3.hed{font-family:var(--serif);font-size:15.5px;font-weight:600;line-height:1.3;margin-bottom:6px;cursor:pointer;}
h3.hed:hover{text-decoration:underline;text-underline-offset:3px;}
.byline{font-family:var(--sans);font-size:11px;color:var(--ink-muted);margin-bottom:10px;}
.byline strong{color:var(--ink);font-weight:600;}
.body-text{font-size:14px;line-height:1.72;}
.body-text p{margin-bottom:10px;}
.read-more{display:inline-block;font-family:var(--sans);font-size:11px;font-weight:600;color:var(--red);text-transform:uppercase;letter-spacing:.08em;margin-top:8px;cursor:pointer;border-bottom:1px solid var(--red);padding-bottom:1px;}
.read-more:hover{opacity:.7;}
/* photo */
.photo-block{margin-bottom:10px;}
.photo-placeholder{width:100%;aspect-ratio:16/9;background:var(--paper-alt);border:1px solid var(--rule);display:flex;align-items:center;justify-content:center;font-family:var(--sans);font-size:11px;color:var(--ink-faint);}
.photo-block img,.article-photo img{width:100%;display:block;border:1px solid var(--rule);}
.caption{font-family:var(--sans);font-size:11px;color:var(--ink-muted);margin-top:4px;font-style:italic;}
/* engage */
.engage{display:flex;align-items:center;gap:14px;margin-top:10px;padding-top:8px;border-top:1px solid var(--rule);}
.engage-btn{font-family:var(--sans);font-size:12px;color:var(--ink-muted);cursor:pointer;display:flex;align-items:center;gap:5px;background:none;border:none;padding:0;transition:color .15s;}
.engage-btn:hover{color:var(--ink);}
.engage-btn.liked{color:var(--red);}
.engage-btn svg{width:14px;height:14px;fill:none;stroke:currentColor;stroke-width:1.8;}
.engage-btn.liked svg{fill:var(--red);stroke:var(--red);}
.engage-count{font-weight:600;}
.share-btn{font-family:var(--sans);font-size:11px;color:var(--ink-muted);cursor:pointer;margin-left:auto;background:none;border:none;padding:0;letter-spacing:.05em;text-transform:uppercase;}
.share-btn:hover{color:var(--ink);}
hr.rule{border:none;border-top:1px solid var(--rule);margin:14px 0;}
/* front page grids */
.most-read-grid{display:grid;grid-template-columns:2fr 1fr;gap:0;margin-bottom:24px;}
.most-read-lead{border-right:1px solid var(--rule);padding-right:28px;padding-bottom:20px;}
.most-read-list{padding-left:24px;}
.rank-item{padding:0 0 14px;margin-bottom:14px;border-bottom:1px solid var(--rule);}
.rank-item:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0;}
.rank-num{font-family:var(--serif);font-size:26px;font-weight:700;color:var(--rule);line-height:1;margin-bottom:4px;}
.badge-strip{display:flex;align-items:center;gap:8px;margin-bottom:4px;}
.badge{font-family:var(--sans);font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;background:var(--red);color:white;padding:2px 7px;}
.badge.gold{background:#7a5c1e;}
.recent-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:0;}
.recent-col{padding-right:24px;border-right:1px solid var(--rule);}
.recent-col:last-child{padding-right:0;border-right:none;padding-left:24px;}
.recent-col:nth-child(2){padding-left:24px;}
.archive-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px 32px;margin-top:4px;}
.archive-card{border-bottom:1px solid var(--rule);padding-bottom:20px;}
/* section pages */
.section-page-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px 32px;}
.section-card{border-bottom:1px solid var(--rule);padding-bottom:20px;}
/* article */
.article-wrap{max-width:720px;margin:0 auto;}
.back-btn{display:inline-flex;align-items:center;gap:6px;font-family:var(--sans);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--ink-muted);cursor:pointer;margin-bottom:24px;background:none;border:none;padding:0;}
.back-btn:hover{color:var(--ink);}
.article-hed{font-family:var(--serif);font-size:34px;font-weight:700;line-height:1.15;margin-bottom:14px;}
.article-byline{font-family:var(--sans);font-size:12px;color:var(--ink-muted);border-top:2px solid var(--ink);border-bottom:1px solid var(--rule);padding:8px 0;margin-bottom:22px;}
.article-byline strong{color:var(--ink);}
.article-photo{margin-bottom:22px;}
.article-photo .photo-placeholder{width:100%;aspect-ratio:16/9;background:var(--paper-alt);border:1px solid var(--rule);display:flex;align-items:center;justify-content:center;font-family:var(--sans);font-size:11px;color:var(--ink-faint);}
.article-body{font-size:16px;line-height:1.78;}
.article-body p{margin-bottom:16px;}
.pull-quote{font-family:var(--serif);font-size:21px;font-style:italic;line-height:1.4;border-top:2px solid var(--ink);border-bottom:1px solid var(--rule);padding:16px 0;margin:26px 0;}
.article-footer{font-family:var(--sans);font-size:11px;color:var(--ink-faint);border-top:1px solid var(--rule);padding-top:14px;margin-top:28px;}
.article-engage{margin:20px 0;padding:12px 0;border-top:1px solid var(--rule);border-bottom:1px solid var(--rule);display:flex;align-items:center;gap:14px;}
/* comments */
.comments-section{margin-top:36px;border-top:2px solid var(--ink);padding-top:20px;}
.comments-title{font-family:var(--sans);font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.1em;margin-bottom:20px;}
.comment{border-bottom:1px solid var(--rule);padding-bottom:16px;margin-bottom:16px;}
.comment:last-of-type{border-bottom:none;}
.comment-meta{font-family:var(--sans);font-size:11px;color:var(--ink-muted);margin-bottom:5px;}
.comment-meta strong{color:var(--ink);font-weight:600;}
.comment-body{font-size:14px;line-height:1.6;}
.comment-likes{font-family:var(--sans);font-size:11px;color:var(--ink-muted);margin-top:6px;cursor:pointer;}
.comment-likes:hover{color:var(--red);}
.closed-notice{font-family:var(--sans);font-size:12px;color:var(--ink-muted);background:var(--paper-alt);border:1px solid var(--rule);padding:12px 16px;margin-top:20px;}
.comment-input-area{margin-top:20px;}
.comment-input-area textarea{width:100%;border:1px solid var(--rule);background:var(--paper-alt);font-family:var(--body);font-size:14px;padding:10px 12px;resize:vertical;min-height:80px;color:var(--ink);}
.comment-submit{font-family:var(--sans);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;background:var(--ink);color:var(--paper);border:none;padding:8px 18px;cursor:pointer;margin-top:8px;}
.comment-submit:hover{opacity:.8;}
.comment-note{font-family:var(--sans);font-size:11px;color:var(--ink-muted);margin-top:6px;}
/* footer */
.site-footer{border-top:2px solid var(--ink);margin-top:48px;padding:20px 32px;display:flex;align-items:center;justify-content:space-between;}
.site-footer-name{font-family:var(--serif);font-size:18px;font-weight:700;}
.site-footer-copy{font-family:var(--sans);font-size:11px;color:var(--ink-muted);}
@media(max-width:768px){
  .site-name{font-size:28px;}
  .most-read-grid,.recent-grid,.archive-grid,.section-page-grid{grid-template-columns:1fr;}
  .most-read-lead{border-right:none;padding-right:0;border-bottom:1px solid var(--rule);padding-bottom:20px;margin-bottom:20px;}
  .most-read-list{padding-left:0;}
  .recent-col,.recent-col:nth-child(2),.recent-col:last-child{padding:0;border-right:none;border-bottom:1px solid var(--rule);padding-bottom:20px;margin-bottom:20px;}
  .page{padding:20px 16px 40px;}
  .site-header{padding:10px 16px 0;}
  .nav a{font-size:10px;padding:7px 10px;}
  .article-hed{font-size:26px;}
  .site-footer{flex-direction:column;gap:8px;text-align:center;}
  .closure-banner{padding:10px 16px;}
}
</style>
</head>
