// ── navigation ────────────────────────────────────────────────
function showView(id) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.getElementById('view-' + id).classList.add('active');
  document.querySelectorAll('.nav a').forEach(a => a.classList.remove('active'));
  const nav = document.getElementById('nav-' + id);
  if (nav) nav.classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function showArticle(id) {
  const a = ARTICLES[id];
  if (!a) return;
  const commentsHTML = a.commentList.map(c => `
    <div class="comment">
      <div class="comment-meta"><strong>${c.user}</strong> &nbsp;·&nbsp; ${c.date}</div>
      <div class="comment-body">${c.text}</div>
      <div class="comment-likes" onclick="this.textContent='♥ ${c.likes+1} people found this helpful'">♥ ${c.likes} people found this helpful</div>
    </div>`).join('');

  const inputHTML = a.commentsOpen
    ? `<div class="comment-input-area">
        <textarea placeholder="Leave a comment..."></textarea>
        <div><button class="comment-submit" onclick="fakeSubmit(this)">Post Comment</button></div>
        <div class="comment-note">Comments are moderated. Please be respectful.</div>
       </div>`
    : `<div class="closed-notice">Comments on this story are closed. The Good Report suspended publication on April 19, 2026.</div>`;

  document.getElementById('article-container').innerHTML = `
    <button class="back-btn" onclick="history.back ? window.dispatchEvent(new CustomEvent('goback')) : showView('front')">← Back</button>
    <div class="kicker hot">${a.kicker}</div>
    <h1 class="article-hed">${a.hed}</h1>
    <div class="article-byline">By <strong>${a.byline}</strong></div>
    <div class="article-photo">${a.photo}</div>
    <div class="article-body">${a.body}</div>
    <div class="article-engage">
      <button class="engage-btn" onclick="toggleLike(this)">
        <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        <span class="engage-count">${a.likes}</span> likes
      </button>
      <button class="share-btn">Share this story</button>
    </div>
    <div class="comments-section">
      <div class="comments-title">${a.comments} Comments</div>
      ${commentsHTML}
      ${inputHTML}
    </div>
    <div class="article-footer">${a.footer}</div>`;

  // store where we came from
  const prevView = document.querySelector('.view.active');
  window._prevView = prevView ? prevView.id.replace('view-','') : 'front';
  showView('article');
}

window.addEventListener('goback', () => showView(window._prevView || 'front'));

// fix back btn after render
document.addEventListener('click', e => {
  if (e.target.classList.contains('back-btn') || e.target.closest('.back-btn')) {
    e.preventDefault();
    showView(window._prevView || 'front');
  }
});

function toggleLike(btn) {
  const countEl = btn.querySelector('.engage-count');
  if (!countEl) return;
  const n = parseInt(countEl.textContent.replace(/,/g,''));
  if (btn.classList.contains('liked')) {
    btn.classList.remove('liked');
    countEl.textContent = (n - 1).toLocaleString();
  } else {
    btn.classList.add('liked');
    countEl.textContent = (n + 1).toLocaleString();
  }
}

function fakeSubmit(btn) {
  const ta = btn.closest('.comment-input-area').querySelector('textarea');
  if (!ta.value.trim()) return;
  const section = btn.closest('.comments-section');
  const div = document.createElement('div');
  div.className = 'comment';
  div.innerHTML = '<div class="comment-meta"><strong>You</strong> &nbsp;·&nbsp; Just now</div><div class="comment-body">' + ta.value.replace(/</g,'&lt;') + '</div><div class="comment-likes">♥ 0 people found this helpful</div>';
  section.insertBefore(div, btn.closest('.comment-input-area'));
  ta.value = '';
}

// start on front page
showView('front');
</script>
